---
const services = [
  "Procurement Services",
  "Operational Office Setup",
  "Cooling Systems",
  "Electrical Engineering",
  "Facility Maintenance",
];
---

<footer>
  <div class="footer-inner">
    <div class="footer-brand">
      <a href="/" class="logo">
        <span class="logo-mark">M</span><span>YKADO</span>
      </a>
      <p>Engineering solutions built on precision, reliability, and expertise.</p>
      <div class="footer-address">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" width="14" height="14">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
        </svg>
        <span>34 Celestial Avenue, Oke-Ira, Off Power Line, Ojodu</span>
      </div>
    </div>

    <div class="footer-col">
      <h4>Services</h4>
      <ul>
        {services.map((s) => <li>{s}</li>)}
      </ul>
    </div>

    <div class="footer-col">
      <h4>Contact</h4>
      <ul>
        <li><a href="tel:+2347030480708">+234 703 048 0708</a></li>
        <li><a href="mailto:mykadoeng@gmail.com">mykadoeng@gmail.com</a></li>
        <li>
          <a href="https://wa.me/2347030480708" target="_blank" rel="noopener noreferrer" class="wa-link">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="13" height="13">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            +234 703 048 0708
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; {new Date().getFullYear()} Mykado Engineering. All rights reserved.</p>
  </div>
</footer>

<style>
  footer {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding: 4rem 2rem 0;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
  }

  .logo {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    display: inline-block;
    margin-bottom: 1rem;
  }

  .logo-mark {
    color: var(--color-accent);
  }

  .footer-brand p {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    max-width: 280px;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .footer-address {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.82rem;
    color: var(--color-text-dim);
    line-height: 1.6;
    max-width: 260px;
  }

  .footer-address svg {
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .footer-col h4 {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1.25rem;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-col li {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .footer-col a:hover {
    color: var(--color-text);
  }

  .wa-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .wa-link svg {
    color: #25D366;
    flex-shrink: 0;
  }

  .wa-link:hover {
    color: var(--color-text);
  }

  .footer-bottom {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.5rem 0;
    border-top: 1px solid var(--color-border);
  }

  .footer-bottom p {
    font-size: 0.78rem;
    color: var(--color-text-dim);
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
