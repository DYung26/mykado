---
const services = [
  "Procurement Services",
  "Operational Office Setup",
  "Cooling Systems",
  "Electrical Engineering",
  "Facility Maintenance",
];
---

<footer>
  <div class="footer-inner">
    <div class="footer-brand">
      <a href="/" class="logo">
        <span class="logo-mark">M</span><span>YKADO</span>
      </a>
      <p>Engineering solutions built on precision, reliability, and expertise.</p>
    </div>

    <div class="footer-col">
      <h4>Services</h4>
      <ul>
        {services.map((s) => <li>{s}</li>)}
      </ul>
    </div>

    <div class="footer-col">
      <h4>Contact</h4>
      <ul>
        <li><a href="mailto:info@mykado.com">info@mykado.com</a></li>
        <li><a href="tel:+2340000000000">+234 000 000 0000</a></li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; {new Date().getFullYear()} Mykado Engineering. All rights reserved.</p>
  </div>
</footer>

<style>
  footer {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding: 4rem 2rem 0;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
  }

  .logo {
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: 0.08em;
    display: inline-block;
    margin-bottom: 1rem;
  }

  .logo-mark {
    color: var(--color-accent);
  }

  .footer-brand p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    max-width: 280px;
    line-height: 1.7;
  }

  .footer-col h4 {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1.25rem;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-col li {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .footer-col a:hover {
    color: var(--color-text);
  }

  .footer-bottom {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.5rem 0;
    border-top: 1px solid var(--color-border);
  }

  .footer-bottom p {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
